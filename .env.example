# QUOTEVERSE AI - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' in the same folder and fill in your keys.

# 1. Google OAuth Web Client ID (Enable real Google Authentication)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# 2. Google AI Studio Gemini key (Enable live AI Generation and Analysis models)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
