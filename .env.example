# QUOTEVERSE AI - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' in the same folder and fill in your keys.

# 1. Firebase Web configuration (Enable real Google Authentication & Firestore)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# 2. Google AI Studio Gemini key (Enable live AI Generation and Analysis models)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
